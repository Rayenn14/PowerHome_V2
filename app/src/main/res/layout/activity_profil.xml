<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <ImageView
                    android:layout_width="410dp"
                    android:layout_height="200dp"
                    android:layout_marginTop="-50dp"
                    android:src="@drawable/image" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="-100dp"
                android:layout_marginLeft="-5dp"
                android:gravity="center"
                android:background="@drawable/radius_img">

                <ImageView
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:src="@drawable/profil"
                    android:scaleType="centerCrop"
                    android:background="@drawable/radius_img"
                    android:clipToOutline="true"/>
            </LinearLayout>

            <TextView
                android:id="@+id/prenom_personne"
                android:layout_width="100dp"
                android:layout_height="30dp"
                android:layout_marginRight="45dp"
                android:text="Prénom"
                android:textStyle="bold"
                android:textSize="20dp"/>

            <TextView
                android:id="@+id/nom_personne"
                android:layout_width="100dp"
                android:layout_height="30dp"
                android:layout_marginLeft="70dp"
                android:layout_marginTop="-30dp"
                android:text="Nom"
                android:textStyle="bold"
                android:textSize="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:layout_marginLeft="25dp"
                android:layout_marginTop="5dp">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginLeft="55dp"
                    android:layout_marginTop="9dp"
                    android:src="@drawable/etoile"/>

                <TextView
                    android:id="@+id/nb_"
                    android:layout_width="55dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="45dp"
                    android:layout_marginLeft="-35dp"
                    android:text="nb"
                    android:paddingStart="15dp"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/nb_malus"
                    android:layout_width="41dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="40dp"
                    android:layout_marginTop="9dp"
                    android:text="nb"
                    android:paddingStart="8dp"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="55dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="-50dp"
                    android:layout_marginTop="45dp"
                    android:text="Malus"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/nb_total"
                    android:paddingStart="8dp"
                    android:layout_width="41dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="9dp"
                    android:text="nb"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="50dp"/>

                <TextView
                    android:layout_width="55dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="-50dp"
                    android:layout_marginTop="45dp"
                    android:text="Total"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="345dp"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/id_name"
                    android:layout_width="150dp"
                    android:layout_height="30dp"
                    android:background="@drawable/edittext_border"
                    android:paddingStart="16dp"/>

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="200dp"
                    android:layout_marginTop="-52dp"
                    android:layout_marginBottom="3dp"
                    android:text="Prenom"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/id_prenom"
                    android:layout_width="170dp"
                    android:layout_height="30dp"
                    android:layout_marginLeft="200dp"
                    android:layout_marginTop="-5dp"
                    android:background="@drawable/edittext_border"
                    android:paddingStart="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Etage"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <Spinner
                            android:id="@+id/spinner_etage"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/edittext_border"
                            android:paddingStart="16dp"
                            android:entries="@array/etage"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Superficie"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <EditText
                            android:id="@+id/superficie"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:background="@drawable/edittext_border"
                            android:paddingStart="16dp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Email"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/edittext_border"
                    android:paddingStart="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Password"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/mdp"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/edittext_border"
                    android:inputType="textPassword"
                    android:paddingStart="16dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSauvergarderEdit"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:backgroundTint="@color/vert_fonce"
                android:text="Sauvergarder"
                android:textSize="18dp"
                android:textStyle="bold"/>
        </LinearLayout>
    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/listView"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu_navigation"
        android:background="@color/blanc_fond"/>
</androidx.drawerlayout.widget.DrawerLayout>
