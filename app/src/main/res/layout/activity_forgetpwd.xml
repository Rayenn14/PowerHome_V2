<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanc_fond"
    android:id="@+id/forgetpwd">

    <ImageView
        android:layout_width="130dp"
        android:layout_height="138dp"
        android:src="@drawable/logo2"
        android:layout_marginTop="61dp"
        android:layout_marginLeft="135dp"/>

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="120dp"
        android:layout_marginTop="240dp"
        android:layout_marginLeft="30dp">
    <TextView
        android:layout_width="250dp"
        android:layout_height="40dp"
        android:text="Mot de passe oublié"
        android:textStyle="bold"
        android:textSize="25sp"/>
        <TextView
            android:layout_width="320dp"
            android:layout_height="40dp"
            android:layout_marginLeft="-250dp"
            android:layout_marginTop="30dp"
            android:text="Entrez votre e-mail enregistré ci-dessous"
            android:textColor="@color/gris_basic"
            android:textSize="17sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="150dp"
        android:layout_marginTop="380dp"
        android:layout_marginLeft="30dp">
        
        <TextView
            android:layout_width="100dp"
            android:layout_height="20dp"
            android:text="Adresse e-mail"
            android:textColor="@color/gris_basic"/>
        
        <EditText
            android:id="@+id/inputEmail"
            android:layout_width="350dp"
            android:layout_height="55dp"
            android:layout_marginLeft="-100dp"
            android:layout_marginTop="45dp"
            android:background="@drawable/edittext_border"
            android:text="app@gmail.com"
            android:textSize="15sp"
            android:paddingStart="19dp"
            android:textColor="#626161"/>

        <TextView
            android:id="@+id/seConnecter_forgetpwd"
            android:layout_width="90dp"
            android:layout_height="20dp"
            android:layout_marginLeft="-350dp"
            android:layout_marginTop="85dp"
            android:text="Se connecter"
            android:textColor="#458244"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnValider"
        android:layout_width="256dp"
        android:layout_height="60dp"
        android:backgroundTint="#458244"
        android:layout_marginTop="600dp"
        android:layout_marginLeft="75dp"
        android:text="Valider"
        android:textSize="20sp"
        />
</RelativeLayout>