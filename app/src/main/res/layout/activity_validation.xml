<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/blanc_fond"
    android:id="@+id/validation">

    <ImageView
        android:layout_width="130dp"
        android:layout_height="138dp"
        android:src="@drawable/logo2"
        android:layout_marginTop="61dp"
        android:layout_marginLeft="135dp"/>

    <ImageView
        android:layout_width="350dp"
        android:layout_height="200dp"
        android:src="@drawable/deco"
        android:layout_marginLeft="40dp"/>

    <LinearLayout
        android:layout_width="350dp"
        android:layout_height="200dp"
        android:layout_marginTop="270dp"
        android:layout_marginLeft="30dp">

        <TextView
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:text="Succès"
            android:textStyle="bold"
            android:textSize="35dp"
            android:layout_marginLeft="115dp"/>

        <TextView
            android:layout_width="250dp"
            android:layout_height="23dp"
            android:text="Merci de vérifier votre email pour créer"
            android:layout_marginLeft="-190dp"
            android:layout_marginTop="30dp"
            android:textColor="#6B6B6B"/>

        <TextView
            android:layout_width="160dp"
            android:layout_height="23dp"
            android:text="le nouveau mot de passe"
            android:layout_marginLeft="-205dp"
            android:layout_marginTop="55dp"
            android:textColor="#6B6B6B"/>

        <TextView
            android:layout_width="95dp"
            android:layout_height="23dp"
            android:text="Pas d'email ?"
            android:layout_marginLeft="-170dp"
            android:layout_marginTop="100dp"
            android:textStyle="bold"
            android:textColor="#6B6B6B"/>

        <TextView
            android:id="@+id/recommencerClick"
            android:layout_width="95dp"
            android:layout_height="23dp"
            android:text="Recommencer"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginTop="100dp"
            android:textStyle="bold"
            android:textColor="#458244"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnValider_validation"
        android:layout_width="256dp"
        android:layout_height="60dp"
        android:backgroundTint="#458244"
        android:layout_marginTop="600dp"
        android:layout_marginLeft="75dp"
        android:text="Se connecter"
        android:textSize="20sp"
        />
</RelativeLayout>