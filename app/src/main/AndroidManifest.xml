<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/powerhome_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/powerhome_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.PowerHome_V2"
        tools:targetApi="31"
        >


        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".SigninActivity" android:exported="false"/>
        <activity android:name=".Mer1Activity" android:exported="false"/>
        <activity android:name=".ForgetpwdActivity" android:exported="false"/>
        <activity android:name=".CalendarActivity" android:exported="false"/>
        <activity android:name=".MainActivity" android:exported="false"/>
        <activity android:name=".NvMdpActivity" android:exported="false"/>
        <activity android:name=".ProfilActivity" android:exported="false"/>
        <activity android:name=".RegisterActivity" android:exported="false"/>
        <activity android:name=".ResidentActivity" android:exported="false"/>
        <activity android:name=".ValidationActivity" android:exported="false"/>
        <activity android:name=".ElectromenagerActivity" android:exported="false"/>
        <activity android:name=".NavMenuActivity" android:exported="false"/>

    </application>

</manifest>
